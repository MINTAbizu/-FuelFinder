# Local dev (Render backend via Vite proxy): the dev server proxies `/api/*` to Render.
VITE_API_BASE_URL=/api

# If you want to use a local backend instead, set:
# VITE_API_BASE_URL=http://localhost:3000/api
#
Production: set `VITE_API_BASE_URL=https://fuelfinder-2.onrender.com` in your hosting environment.
