{
  "expo": {
    "name": "fuelfinder",
    "slug": "fuelfinder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fuelfinder",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mintesenotbizuayehw.fuelfinder"
    },
    "android": {
      "package": "com.mintesenotbizuayehw.fuelfinder",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-localization",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow FuelFinder to use Face ID to unlock your account securely."
        }
      ],
      "expo-secure-store",
      "./plugins/withAndroidX",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow FuelFinder to access your location to find nearby fuel stations."
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "fuelfinder",
          "project": "fuelfinder"
        }
      ],
      "@sentry/react-native"
    ],
    "extra": {
      "sentry": {
        "dsn": "https://e80bcf5574ef345c2c5f51cd7e53bcb6@o4510905935003648.ingest.us.sentry.io/4511011593846784",
        "environment": "production",
        "org": "fuelfinder",
        "project": "fuelfinder"
      },
      "eas": {
        "projectId": "b3ee0134-33a4-4fc6-812c-1168dae601fb"
      }
    },
    "owner": "mintesenotb"
  }
}
