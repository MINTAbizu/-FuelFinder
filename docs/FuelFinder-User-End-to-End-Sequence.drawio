        <mxCell id="note_auth" value="Authentication branch options:&#xa;- Register&#xa;- Password login&#xa;- Google sign-in&#xa;- Biometric login&#xa;- Forgot password&#xa;If required, the app uses VerifyPhone for phone OTP, two-factor OTP, and password-reset OTP." style="shape=note;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#475569;" vertex="1" parent="1">
